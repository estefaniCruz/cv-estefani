---
import { Icon } from "astro-icon/components";
import Button from "../ui/Button.astro";

interface SocialLink {
  icon: string;
  label: string;
  href: string;
}

interface Props {
  title: string;
  description: string;
  icon: string;
  email_label: string;
  email_href: string;
  links: SocialLink[];
}

const {
  title,
  description,
  icon,
  email_label,
  email_href,
  links
} = Astro.props as Props;
---

<section id="contacto" class="scroll-mt-24 py-10">
  <div class="rounded-3xl bg-brand-100 p-8 md:flex md:items-center md:justify-between md:gap-8">
    
    <!-- IZQUIERDA -->
    <div class="flex items-start gap-5">
      <div class="flex size-16 items-center justify-center rounded-full bg-brand-600 text-white">
        <Icon name={icon} class="size-8" />
      </div>

      <div>
        <h2 class="text-xl font-extrabold uppercase tracking-tight text-text">
          {title}
        </h2>

        <p class="mt-3 max-w-xl text-text">
          {description}
        </p>
      </div>
    </div>

    <!-- DERECHA -->
    <div class="mt-6 flex items-center gap-5 md:mt-0">
      
      <!-- BOTÓN EMAIL -->
      <Button
        href={email_href}
        variant="secondary"
        size="lg"
        iconName="mdi:email-outline"
      >
        {email_label}
      </Button>

      <!-- REDES -->
      {
        links.map((link) => (
          <a
            href={link.href}
            aria-label={link.label}
            target="_blank"
            rel="noopener noreferrer"
            class="text-text transition hover:text-brand-600"
          >
            <Icon name={link.icon} class="size-10" />
          </a>
        ))
      }
    </div>

  </div>
</section>