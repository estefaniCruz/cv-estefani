---
import { Icon } from "astro-icon/components";

interface NavItem {
  label: string;
  href: string;
}

interface Props {
  name: string;
  items: NavItem[];
}

const { name, items } = Astro.props as Props;
---

<header class="sticky top-4 z-50 mx-6 md:mx-16 md:max-w-8xl rounded-2xl border border-border bg-surface/90 shadow-sm backdrop-blur">
  <div class="flex h-16 items-center justify-between px-5">
    <a href="#top" class="font-display text-lg font-bold text-heading">
      {name}
    </a>

    <nav class="hidden items-center gap-8 md:flex" aria-label="Navegación principal">
      {items.map((item) => (
        <a
          href={item.href}
          class="text-sm font-semibold text-text-muted transition hover:text-brand-600 dark:hover:text-brand-300"
        >
          {item.label}
        </a>
      ))}
    </nav>

    <details class="relative md:hidden">
      <summary class="cursor-pointer list-none rounded-lg px-3 py-2 text-sm font-semibold text-text">
        <Icon name="mdi:menu" class="size-5" />
      </summary>

      <nav class="absolute right-0 mt-3 w-56 rounded-2xl border border-border bg-surface p-3 shadow-lg">
        {items.map((item) => (
          <a
            href={item.href}
            class="block rounded-xl px-4 py-3 text-sm font-semibold text-text-muted hover:bg-surface-2 hover:text-text"
          >
            {item.label}
          </a>
        ))}
      </nav>
    </details>
  </div>
</header>